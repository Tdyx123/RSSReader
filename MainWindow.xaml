<Window x:Class="RSSReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RSSReader.ViewModels"
        mc:Ignorable="d"
        Title="RSS Reader - AI 智能阅读器"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFBFC">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📰" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="RSS Reader" FontSize="20" FontWeight="Bold" 
                               Foreground="#1F2937" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" 
                            Command="{Binding RefreshAllCommand}" 
                            ToolTip="刷新所有订阅"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,6,0"/>
                            <TextBlock Text="刷新"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" 
                            Command="{Binding OpenSettingsCommand}" 
                            Margin="8,0,0,0"
                            ToolTip="设置">
                        <TextBlock Text="⚙️"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" MaxWidth="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - Feeds -->
            <Border Grid.Column="0" Background="#F0F2F5" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add Feed -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="8,8,8,0">
                        <StackPanel>
                            <TextBlock Text="添加订阅" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,8"/>
                            <TextBlock Text="RSS 地址" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewFeedUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8" Margin="0,0,0,8"
                                     BorderBrush="#E5E7EB" BorderThickness="1"/>
                            <TextBlock Text="分类（可选）" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewFeedCategory, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8" Margin="0,0,0,8"
                                     BorderBrush="#E5E7EB" BorderThickness="1"/>
                            <Button Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding AddFeedCommand}"
                                    Content="添加"/>
                        </StackPanel>
                    </Border>

                    <!-- Feed List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Feeds}"
                             SelectedItem="{Binding SelectedFeed}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="8,8,8,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,2" CornerRadius="6" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32" 
                                                CornerRadius="4" Background="#E5E7EB" Margin="0,0,10,0">
                                            <TextBlock Text="📡" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="Medium" 
                                                       Foreground="#1F2937" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Delete Feed Button -->
                    <Button Grid.Row="2" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding DeleteFeedCommand}"
                            Margin="8" Content="删除选中订阅"/>
                </Grid>
            </Border>

            <!-- Right Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Article Detail -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" 
                        Visibility="{Binding SelectedArticle, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="{Binding SelectedArticle.Title}"
                                   FontSize="20" FontWeight="Bold" Foreground="#1F2937"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <!-- Meta Info -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedArticle.PublishDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       Foreground="#6B7280" FontSize="12"/>
                            <TextBlock Text=" | " Foreground="#E5E7EB"/>
                            <TextBlock Text="{Binding SelectedArticle.Feed.Title}" Foreground="#6B7280" FontSize="12"/>
                            <Border Background="#F3E8FF" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock Text="🤖 AI" FontSize="11" Foreground="#7C3AED"/>
                            </Border>
                        </StackPanel>

                        <!-- AI Summary -->
                        <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="AI 摘要" FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedArticle.AiSummary}" 
                                           TextWrapping="Wrap" Foreground="#374151"
                                           Visibility="{Binding SelectedArticle.AiSummary, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="点击生成摘要..." Foreground="#9CA3AF" FontStyle="Italic"
                                           Visibility="{Binding SelectedArticle.AiSummary, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding GenerateSummaryCommand}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✨" Margin="0,0,4,0"/>
                                    <TextBlock Text="生成摘要"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding OpenArticleLinkCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔗" Margin="0,0,4,0"/>
                                    <TextBlock Text="查看原文"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding ToggleStarCommand}" Margin="8,0,0,0">
                                <TextBlock Text="{Binding SelectedArticle.IsStarred, Converter={StaticResource BoolToVis}}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tab Control -->
                <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" 
                            Background="Transparent" BorderThickness="0" Margin="8,0,8,8">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- Articles Tab -->
                    <TabItem Header="📰 文章列表">
                        <ListBox ItemsSource="{Binding Articles}"
                                 SelectedItem="{Binding SelectedArticle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                                       FontWeight="SemiBold" Foreground="#1F2937"
                                                       TextTrimming="CharacterEllipsis" FontSize="14"/>

                                            <TextBlock Grid.Row="1" Text="{Binding Description}"
                                                       Foreground="#6B7280" TextWrapping="Wrap"
                                                       MaxHeight="60" TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0"/>

                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding PublishDate, StringFormat='{}{0:MM/dd}'}"
                                                           FontSize="11" Foreground="#9CA3AF"/>
                                                <TextBlock Text=" | " Foreground="#E5E7EB"/>
                                                <TextBlock Text="{Binding Feed.Title}" FontSize="11" Foreground="#9CA3AF"/>
                                                <TextBlock Text=" | " Foreground="#E5E7EB" 
                                                           Visibility="{Binding IsStarred, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="⭐" Foreground="#FBBF24" 
                                                           Visibility="{Binding IsStarred, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>

                    <!-- Event Line Tab -->
                    <TabItem Header="⚡ 事件线">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                                <Button Style="{StaticResource PrimaryButton}" 
                                        Command="{Binding GenerateEventLineCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" Margin="0,0,4,0"/>
                                        <TextBlock Text="生成事件线"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="(需要配置 GLM API Key)" Foreground="#9CA3AF" 
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            </StackPanel>

                            <ListBox Grid.Row="1" ItemsSource="{Binding EventLineItems}"
                                     Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Width="12" Height="12" 
                                                        CornerRadius="6" Background="#F97316" Margin="0,0,16,0"/>

                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding EventDate, StringFormat='{}{0:MM/dd}'}"
                                                                   FontWeight="Bold" Foreground="#F97316" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" 
                                                                   Foreground="#1F2937"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" 
                                                               Foreground="#6B7280" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- Chat Tab -->
                    <TabItem Header="💬 问答">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                                <Button Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding ClearChatCommand}">
                                    <TextBlock Text="🗑️ 清空对话"/>
                                </Button>
                                <TextBlock Text="(需要配置 GLM API Key)" Foreground="#9CA3AF" 
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ChatMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="8" Padding="12" CornerRadius="8"
                                                    MaxWidth="500"
                                                    HorizontalAlignment="{Binding Role, Converter={StaticResource BoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F3F4F6"/>
                                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                                <Setter Property="Background" Value="#F3E8FF"/>
                                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="👤"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                                        <Setter Property="Text" Value="🤖"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#1F2937"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" 
                                    BorderThickness="0,1,0,0" Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" 
                                             Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12" FontSize="14"
                                             BorderBrush="#E5E7EB" BorderThickness="1">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding SendQuestionCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>

                                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" 
                                            Command="{Binding SendQuestionCommand}" Margin="8,0,0,0">
                                        <TextBlock Text="发送"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                           Foreground="#6B7280" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Articles.Count, StringFormat='{}{0} 篇文章'}" Foreground="#6B7280"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" Background="#80000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="16" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
